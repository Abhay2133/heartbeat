# Heartbeat Service Configuration Template
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000

# Heartbeat URL to ping (defaults to local health endpoint if not set)
HEARTBEAT_URL=http://localhost:3000/health

# Google Cloud Platform Configuration
# Project ID (any of these three can be used)
GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GCLOUD_PROJECT=your-gcp-project-id

# GCP Compute Engine Instance Configuration
GCP_ZONE=us-central1-a
GCP_INSTANCE_NAME=your-instance-name

# Restart Strategy: 'start' (default) or 'reset'
GCP_RESTART_STRATEGY=start

# Cooldown period in seconds between restart attempts (default: 300 = 5 minutes)
RESTART_COOLDOWN_SECONDS=300

# Google Cloud Authentication
# Set this to the path of your service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json